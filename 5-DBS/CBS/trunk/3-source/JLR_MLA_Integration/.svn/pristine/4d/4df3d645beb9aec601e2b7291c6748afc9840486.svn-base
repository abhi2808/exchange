<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>
        DailyBuildSystem build report
    </title>
    <style type="text/css">
	.redtext {
        color: red;
		font-size:11.0pt;
		font-family:"맑은 고딕", arial;
	}
	body {
		font-size:10.0pt;
		font-family:"맑은 고딕", arial;
	}
	
	.fail {
		color:red;
	}
	
	.success {
		color: blue;
	}
		
	.fatal {
		color: red;
	}
		
	.build-result-table {
		border-collapse: collapse;
	}
	.build-result-table th, 
	.build-result-table td {
		border: 1px solid #e1edff;
		padding: 7px 17px;
	}
	
	/* Table Header */
	.build-result-table thead th {
		background-color: #508abb;
		color: #FFFFFF;
		border-color: #6ea1cc !important;
	}
	
	/* Table Body */
	.build-result-table tbody td {
		color: #353535;
	}
	.build-result-table tbody td:first-child {
		text-align: right;
	}
	.build-result-table tbody tr:nth-child(odd) td {
		background-color: #f4fbff;
	}
    </style>
</head>
<body>
<p>
<h3>
    Build Result :
    %if is_success :
        &nbsp<span class="success">SUCCESS</span>
    %else :
        &nbsp<span class="fail">FAIL</span>
    %endif
</h3>
</p>

<p>
<table class="build-result-table">
    <thead>
    <tr>
        <th colspan=2>Build Information</th>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td>Date</td>
        <td>${args["date"]}</td>
    </tr>
    <tr>
        <td>Time</td>
        <td>${args["time"]}</td>
    </tr>
    <tr>
        <td>SVN URL</td>
        <td>${args["jenkins"]["SVN_URL"]}</td>
    </tr>
    <tr>
        <td>SVN rev.</td>
        <td>${args["jenkins"]["SVN_REVISION"]}</td>
    </tr>
	<tr>
        <td>Build Package</td>
        <td>${args["extras"][3]}</td>
    </tr>
    <tr>
        <td>Car Maker</td>
        <td>${args["extras"][0]}</td>
    </tr>
    <tr>
        <td>Car Name</td>
        <td>${args["extras"][1]}</td>
    </tr>
    <tr>
        <td>Variant</td>
        <td>${args["extras"][2]}</td>
    </tr>
	</tbody>
%if args.__contains__("dbs_release"):
    <thead>
    <tr>
        <th colspan=2>Release Information</th>
    </tr>
    </thead>
    <tbody>
%if args["dbs_release"].__contains__("dbs_release_jenkins"):
	<tr>
        <td>Archive</td>
        <td><a href=${args["dbs_release"]["dbs_release_jenkins"]}>DOWNLOAD</a></td>
    </tr>
%endif
%if args["dbs_release"].__contains__("dbs_release_svn"):
	<tr>
        <td>SVN</td>
        <td><a href=${args["dbs_release"]["dbs_release_svn"]}>link</a></td>
    </tr>
%endif
	</tbody>
%endif
</table>
</p>
<p>
<h3>
    %if is_fatal :
        &nbsp<span class="fatal">FATAL ERROR FOUND ! PLEASE BUILD AGAIN.</span>
    %endif
</h3>
</p>
<p>
    Check console output <a href=${args["jenkins"]["BUILD_URL"]}>here</a> to view the complete result.
</p>
</body>
</html>
